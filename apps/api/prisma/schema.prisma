generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id
  email String @unique
  name String
  password String
  role Role
  imgUrl String?
  createdAt DateTime
  updatedAt DateTime
}

model RegistrationToken {
  id String @id @default(uuid())
  token String
}

enum Role {
  USER
  ADMIN
}