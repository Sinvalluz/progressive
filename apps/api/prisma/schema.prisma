generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id
  email String @unique
  name String
  password String
  role Role
  imgUrl String?
  createAt DateTime
  updateAt DateTime
  refreshTokens RefreshTokens[]
}

model RegistrationToken {
  id String @id @default(uuid())
  token String
}

model RefreshTokens {
  id String @id
  refreshToken String
  userId String
  createAt DateTime
  updateAt DateTime

  user User @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
}